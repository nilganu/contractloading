# Copy to backend/.env

# Leave OPENAI_API_KEY empty to run in deterministic-stub mode (no real LLM calls)
OPENAI_API_KEY=
# Pick the model that suits cost / quality:
#   gpt-5.4-mini   — $0.75/$4.50 per M tokens (cheap, fast, recommended default)
#   gpt-4o         — $2.50/$10 per M tokens   (strong vision, more expensive)
#   gpt-4o-mini    — even cheaper but weaker on table extraction
OPENAI_MODEL=gpt-5.4-mini
OPENAI_VISION_MODEL=gpt-5.4-mini

DATABASE_URL=sqlite:///./hotel.db
STORAGE_DIR=./storage

CHILD_COLUMN_MODE=dynamic_review
PRESERVE_CHILD_POSITIONS=true

PROMPT_VERSION=v1
PARSER_VERSION=v1

ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
